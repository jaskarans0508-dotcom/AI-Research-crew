[project]
name = "research-crew"
version = "0.1.0"
description = "A tiny 3-agent crew (Researcher, Writer, Reviewer) that turns a topic into a sourced brief, with a live web UI."
readme = "README.md"
requires-python = ">=3.9"
license = { text = "MIT" }
authors = [{ name = "Jaskaran" }]
dependencies = [
    "anthropic>=0.34.0",
    "fastapi>=0.110",
    "uvicorn>=0.29",
    "httpx>=0.27",
]

[project.optional-dependencies]
dev = ["pytest>=7.0"]
tavily = ["tavily-python>=0.5"]

[project.scripts]
research-crew = "research_crew.__main__:main"

[build-system]
requires = ["setuptools>=61.0"]
build-backend = "setuptools.build_meta"

[tool.setuptools.packages.find]
include = ["research_crew*"]

[tool.setuptools.package-data]
research_crew = ["static/*.html"]
